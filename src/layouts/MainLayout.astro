---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.jsx";

type SocialLink = {
  label: string;
  href: string;
  meta?: string;
};

type LayoutSite = {
  brand?: string;
  name?: string;
  role?: string;
  email?: string;
  socialLinks?: SocialLink[];
};

const {
  title = "Portfolio",
  description = "Modern portfolio website",
  site,
}: {
  title?: string;
  description?: string;
  site?: LayoutSite;
} = Astro.props;

const socialLinks = site?.socialLinks ?? [];
const footerLinks = socialLinks.filter(
  ({ label }) => label === "GitHub" || label === "LinkedIn",
);
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const initialTheme =
        savedTheme === "light" || savedTheme === "dark" ? savedTheme : "dark";

      document.documentElement.setAttribute("data-theme", initialTheme);
    </script>
    <noscript>
      <style>
        #site-loader {
          display: none;
        }
      </style>
    </noscript>
  </head>

  <body>
    <div id="site-loader" class="site-loader" aria-hidden="true">
      <div class="site-loader-scene">
        <div class="loader-sun"></div>
        <div class="loader-cloud loader-cloud-one"></div>
        <div class="loader-cloud loader-cloud-two"></div>
        <div class="loader-ocean-glow"></div>

        <div class="loader-ocean">
          <span class="loader-wave loader-wave-one"></span>
          <span class="loader-wave loader-wave-two"></span>
          <span class="loader-wave loader-wave-three"></span>
        </div>

        <div class="loader-shore"></div>

        <div class="loader-copy">
          <strong>Loading portfolio</strong>
          <span>Preparing the experience</span>
        </div>

        <div class="loader-progress" aria-hidden="true">
          <div class="loader-progress-track">
            <div class="loader-progress-fill">
              <div class="loader-turtle">
                <span class="loader-turtle-leg loader-turtle-leg-back"></span>
                <span class="loader-turtle-leg loader-turtle-leg-front"></span>
                <span class="loader-turtle-shell"></span>
                <span class="loader-turtle-head"></span>
                <span class="loader-turtle-tail"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="ambient-orb ambient-orb-one"></div>
    <div class="ambient-orb ambient-orb-two"></div>
    <div class="ambient-orb ambient-orb-three"></div>

    <header class="site-header">
      <div class="container nav-wrap">
        <a href="#home" class="brand">
          <span class="brand-mark">{site?.brand ?? "Portfolio"}.</span>
          <span class="brand-copy">
            <strong>{site?.name ?? "Your Full Name"}</strong>
            <small>{site?.role ?? "Portfolio Owner"}</small>
          </span>
        </a>

        <div class="nav-frame">
          <nav class="nav">
            <a href="#home">Home</a>
            <a href="#about">About</a>
            <a href="#skills">Skills</a>
            <a href="#projects">Projects</a>
            <a href="#experience">Experience</a>
            <a href="#contact">Contact</a>
          </nav>

          <div class="nav-utilities">
            <ThemeToggle client:load />
          </div>
        </div>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-minimal">
        <p class="footer-name">{site?.name ?? "Your Full Name"}</p>

        <div class="footer-meta">
          <span>&copy; {currentYear}</span>

          {footerLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer" class="footer-link">
              {item.label}
            </a>
          ))}

          <a href={`mailto:${site?.email ?? ""}`} class="footer-link">
            Email
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const loader = document.getElementById("site-loader");
      const loaderScene = loader?.querySelector(".site-loader-scene");
      let loaderProgress = 8;
      let targetProgress = 88;
      let progressFrame = 0;

      const setLoaderProgress = (value) => {
        loaderScene?.style.setProperty("--loader-progress", `${value}%`);
      };

      const animateLoaderProgress = () => {
        const easing = targetProgress >= 100 ? 0.14 : 0.05;
        loaderProgress += (targetProgress - loaderProgress) * easing;

        if (Math.abs(targetProgress - loaderProgress) < 0.18) {
          loaderProgress = targetProgress;
        }

        setLoaderProgress(loaderProgress);

        if (loaderProgress !== targetProgress) {
          progressFrame = window.requestAnimationFrame(animateLoaderProgress);
        } else {
          progressFrame = 0;
        }
      };

      const startLoaderProgress = () => {
        if (!progressFrame) {
          progressFrame = window.requestAnimationFrame(animateLoaderProgress);
        }
      };

      const hideLoader = () => {
        if (!loader) return;

        loader.classList.add("is-hidden");
        window.setTimeout(() => loader.remove(), 900);
      };

      const finishLoader = () => {
        targetProgress = 100;
        startLoaderProgress();
        window.setTimeout(hideLoader, 650);
      };

      setLoaderProgress(loaderProgress);
      startLoaderProgress();

      if (document.readyState === "complete") {
        finishLoader();
      } else {
        window.addEventListener(
          "load",
          () => {
            finishLoader();
          },
          { once: true },
        );
      }
    </script>
  </body>
</html>
