---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.jsx";
import InteractiveBubbles from "../components/InteractiveBubbles.jsx";

type SocialLink = {
  label: string;
  href: string;
  meta?: string;
};

type LayoutSite = {
  brand?: string;
  name?: string;
  role?: string;
  email?: string;
  location?: string;
  availability?: string;
  socialLinks?: SocialLink[];
};

const {
  title = "Portfolio",
  description = "Modern portfolio website",
  site,
}: {
  title?: string;
  description?: string;
  site?: LayoutSite;
} = Astro.props;

const socialLinks = site?.socialLinks ?? [];
const footerLinks = socialLinks.filter(
  ({ label }) => label === "GitHub" || label === "LinkedIn",
);
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/mylogo.png" />
    <link rel="shortcut icon" href="/mylogo.png" />
    <link rel="apple-touch-icon" href="/mylogo.png" />
    <title>{title}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const initialTheme =
        savedTheme === "light" || savedTheme === "dark" ? savedTheme : "dark";

      document.documentElement.setAttribute("data-theme", initialTheme);
    </script>
    <noscript>
      <style>
        #site-loader {
          display: none;
        }
      </style>
    </noscript>
  </head>

  <body>
    <div id="site-loader" class="site-loader" aria-hidden="true">
      <div class="site-loader-scene">
        <div class="loader-sun"></div>
        <div class="loader-cloud loader-cloud-one"></div>
        <div class="loader-cloud loader-cloud-two"></div>
        <div class="loader-ocean-glow"></div>

        <div class="loader-ocean">
          <span class="loader-wave loader-wave-one"></span>
          <span class="loader-wave loader-wave-two"></span>
          <span class="loader-wave loader-wave-three"></span>
        </div>

        <div class="loader-shore"></div>

        <div class="loader-copy">
          <strong>Loading portfolio</strong>
          <span>Preparing the experience</span>
        </div>

        <div class="loader-progress" aria-hidden="true">
          <div class="loader-progress-track">
            <div class="loader-progress-fill">
              <div class="loader-turtle">
                <span class="loader-turtle-leg loader-turtle-leg-back"></span>
                <span class="loader-turtle-leg loader-turtle-leg-front"></span>
                <span class="loader-turtle-shell"></span>
                <span class="loader-turtle-head"></span>
                <span class="loader-turtle-tail"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="ambient-orb ambient-orb-one"></div>
    <div class="ambient-orb ambient-orb-two"></div>
    <div class="ambient-orb ambient-orb-three"></div>
    <InteractiveBubbles client:idle />
    <div class="page-progress" aria-hidden="true">
      <span id="page-progress-bar" class="page-progress-bar"></span>
    </div>

    <header class="site-header">
      <div class="container nav-wrap">
        <a href="#home" class="brand">
          <span class="brand-mark">{site?.brand ?? "Portfolio"}.</span>
        </a>

        <div class="nav-shell" data-nav-shell>
          <div class="nav-frame" id="site-nav-frame">
            <nav class="nav">
              <a href="#home">Home</a>
              <a href="#about">About</a>
              <a href="#skills">Skills</a>
              <a href="#projects">Projects</a>
              <a href="#experience">Experience</a>
              <a href="#contact">Contact</a>
            </nav>
          </div>

          <div class="theme-toggle-dock">
            <ThemeToggle client:load />
          </div>

          <button
            type="button"
            class="nav-toggle"
            data-nav-toggle
            aria-expanded="false"
            aria-controls="site-nav-frame"
            aria-label="Open navigation menu"
          >
            <span class="nav-toggle-lines" aria-hidden="true">
              <span class="nav-toggle-line"></span>
              <span class="nav-toggle-line"></span>
              <span class="nav-toggle-line"></span>
            </span>
          </button>
        </div>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-minimal">
        <div class="footer-signoff">
          <p class="footer-name">{site?.name ?? "Your Full Name"}</p>
          <p class="footer-note">
            {site?.location ?? "Your Location"}
            {site?.availability && <span> | {site.availability}</span>}
          </p>
        </div>

        <div class="footer-meta">
          <span>&copy; {currentYear}</span>

          {footerLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer" class="footer-link">
              {item.label}
            </a>
          ))}

          <a href={`mailto:${site?.email ?? ""}`} class="footer-link">
            Email
          </a>

          <a href="#home" class="footer-link">Back to top</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const navShell = document.querySelector("[data-nav-shell]");
      const navToggle = document.querySelector("[data-nav-toggle]");
      const navFrame = document.getElementById("site-nav-frame");
      const navLinks = navFrame?.querySelectorAll('a[href^="#"]') ?? [];
      const mobileNavQuery = window.matchMedia("(max-width: 860px)");
      const pageProgressBar = document.getElementById("page-progress-bar");
      const loader = document.getElementById("site-loader");
      const loaderScene = loader?.querySelector(".site-loader-scene");
      let loaderProgress = 8;
      let targetProgress = 88;
      let progressFrame = 0;
      let scrollFrame = 0;

      const setLoaderProgress = (value) => {
        loaderScene?.style.setProperty("--loader-progress", `${value}%`);
      };

      const animateLoaderProgress = () => {
        const easing = targetProgress >= 100 ? 0.14 : 0.05;
        loaderProgress += (targetProgress - loaderProgress) * easing;

        if (Math.abs(targetProgress - loaderProgress) < 0.18) {
          loaderProgress = targetProgress;
        }

        setLoaderProgress(loaderProgress);

        if (loaderProgress !== targetProgress) {
          progressFrame = window.requestAnimationFrame(animateLoaderProgress);
        } else {
          progressFrame = 0;
        }
      };

      const startLoaderProgress = () => {
        if (!progressFrame) {
          progressFrame = window.requestAnimationFrame(animateLoaderProgress);
        }
      };

      const updatePageProgress = () => {
        const scrollHeight =
          document.documentElement.scrollHeight - window.innerHeight;
        const progress =
          scrollHeight > 0 ? Math.min(window.scrollY / scrollHeight, 1) : 0;

        pageProgressBar?.style.setProperty(
          "transform",
          `scaleX(${progress.toFixed(4)})`,
        );
        scrollFrame = 0;
      };

      const requestPageProgress = () => {
        if (!scrollFrame) {
          scrollFrame = window.requestAnimationFrame(updatePageProgress);
        }
      };

      const setNavState = (open) => {
        if (!navShell || !navToggle) return;

        const isMobile = mobileNavQuery.matches;
        const shouldOpen = isMobile && open;
        navShell.classList.toggle("is-open", shouldOpen);
        navToggle.setAttribute("aria-expanded", String(shouldOpen));
        navToggle.setAttribute(
          "aria-label",
          shouldOpen ? "Close navigation menu" : "Open navigation menu",
        );
      };

      const closeNav = () => {
        setNavState(false);
      };

      const syncNavMode = () => {
        if (!mobileNavQuery.matches) {
          closeNav();
        }
      };

      const hideLoader = () => {
        if (!loader) return;

        loader.classList.add("is-hidden");
        window.setTimeout(() => loader.remove(), 900);
      };

      const finishLoader = () => {
        targetProgress = 100;
        startLoaderProgress();
        window.setTimeout(hideLoader, 650);
      };

      setLoaderProgress(loaderProgress);
      startLoaderProgress();
      updatePageProgress();
      window.addEventListener("scroll", requestPageProgress, { passive: true });
      window.addEventListener("resize", requestPageProgress);
      window.addEventListener("resize", syncNavMode);

      navToggle?.addEventListener("click", () => {
        const isOpen = navShell?.classList.contains("is-open");
        setNavState(!isOpen);
      });

      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          closeNav();
        });
      });

      document.addEventListener("click", (event) => {
        if (!mobileNavQuery.matches || !navShell?.classList.contains("is-open")) {
          return;
        }

        if (navShell.contains(event.target)) {
          return;
        }

        closeNav();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeNav();
        }
      });

      if (document.readyState === "complete") {
        finishLoader();
      } else {
        window.addEventListener(
          "load",
          () => {
            finishLoader();
          },
          { once: true },
        );
      }
    </script>
  </body>
</html>
